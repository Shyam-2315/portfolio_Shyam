APP_NAME="Neural Command Center API"
ENVIRONMENT=production

# Use Neon, Supabase, Render PostgreSQL, Railway PostgreSQL, or another managed Postgres URL.
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Generate a long random value. Do not reuse the local development secret.
JWT_SECRET_KEY=replace-with-a-long-random-production-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Set both values to the deployed frontend origin.
FRONTEND_URL=https://your-frontend.vercel.app
CORS_ORIGINS=https://your-frontend.vercel.app

# Local disk uploads are temporary on Render/Railway unless you attach persistent storage.
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# Used by seed_admin.py during initial production setup.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-production-password
